{
  "name": "zoho-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for Zoho Books, Inventory, and CRM",
  "main": "dist/index.js",
  "scripts": {
    "build": "node ./node_modules/esbuild/bin/esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --external:@modelcontextprotocol/sdk --external:axios --external:express --external:zod",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.0",
    "esbuild": "^0.20.0",
    "express": "^4.18.2",
    "fast-xml-parser": "^5.5.11",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/swagger-ui-express": "^4.1.8",
    "typescript": "^5.3.2"
  }
}
